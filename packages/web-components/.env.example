# UI Components – Development Environment
# Copy this file to .env and fill in your values.

# ── SignalWire tokens & destinations ──────────────────────────────────────────
# Each token is paired with the destination it dials.
# Used in stories via import.meta.env.VITE_C2C_TOKEN / VITE_C2C_DEST etc.
# (dotenv-expand propagates these to the VITE_* vars below automatically)

C2C_TOKEN=
C2C_DEST=

C2T_TOKEN=
C2T_DEST=

SAT_TOKEN=
SAT_DEST=

VITE_C2C_TOKEN=${C2C_TOKEN}
VITE_C2C_DEST=${C2C_DEST}
VITE_C2T_TOKEN=${C2T_TOKEN}
VITE_C2T_DEST=${C2T_DEST}
VITE_SAT_TOKEN=${SAT_TOKEN}
VITE_SAT_DEST=${SAT_DEST}

# ── Test / Playwright ─────────────────────────────────────────────────────────

# Development server port
DEV_PORT=3000

# Test server port (for Playwright)
TEST_PORT=3000

# Set to 'headed' for a visible browser during tests
PLAYWRIGHT_BROWSER_MODE=headless

# Enable debug logging
DEBUG=false

# CI environment flag
CI=false