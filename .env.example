# SignalWire Environment Variables
# Copy this file to .env and fill in your actual values
# Used by scripts/issue-sat.js to generate Subscriber Access Tokens (SAT)

# Your SignalWire space name (e.g., "your-space" from your-space.signalwire.com)
SW_SPACE=your-space-name

# SignalWire domain (typically signalwire.com)
SW_DOMAIN=signalwire.com

# Subscriber reference identifier (e.g., username or email)
SW_SUBSCRIBER_REFERENCE=your-subscriber-reference

# Password for the subscriber
SW_SUBSCRIBER_PASSWORD=your-subscriber-password

# Fabric Application ID (optional, included in token request if set)
# SW_APPLICATION_ID=your-application-id

# SignalWire Project ID (from Dashboard > Settings > API)
SW_PROJECT_ID=your-project-id

# SignalWire API Token (from Dashboard > Settings > API)
SW_API_TOKEN=your-api-token
