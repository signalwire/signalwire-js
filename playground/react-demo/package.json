{
  "name": "@signalwire/react-demo",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "description": "React demo showcasing @signalwire/js and @signalwire/web-components with RxJS-to-React integration",
  "scripts": {
    "dev": "rm -rf node_modules/.vite && vite",
    "dev:sat": "rm -rf node_modules/.vite && SAT_TOKEN=$(node ../../scripts/issue-sat.js --env-file ../../.env) vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@signalwire/js": "4.0.0-rc.2",
    "@signalwire/web-components": "4.0.0-rc.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4",
    "typescript": "~5.9.3",
    "vite": "^7.2.2"
  }
}
