# SignalWire WebRTC Demo Environment Variables

# SAT Token for direct authentication (used for testing)
# Obtain from SignalWire Dashboard
VITE_SAT_TOKEN=your_sat_token_here

# Token endpoint URL (alternative to direct token)
# Should return JSON: {"token": "..."}
VITE_TOKEN_URL=https://your-server.com/api/token

# Development server port (optional, defaults to 3000)
VITE_PORT=3000

# Test configuration
# Base URL for Playwright tests
BASE_URL=http://localhost:3000

# CI environment flag
CI=false
