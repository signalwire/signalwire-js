#!/usr/bin/env python3
"""
up_next - CLI tool to manage test suite progress for autonomous iteration work.

Usage:
    up_next --verify                    Select 2 random passing tests for re-validation
    up_next --feature                   Get the next feature to implement (first non-passing)
    up_next --completed <description>   Mark a test as passing
    up_next --fix-priority <description> Mark a test as failing (needs fix)
"""

import argparse
import json
import random
import sys
from pathlib import Path


def get_test_suite_path() -> Path:
    """Get the path to test_suite.json in the project root."""
    script_dir = Path(__file__).resolve().parent
    project_root = script_dir.parent
    return project_root / "test_suite.json"


def load_test_suite() -> list:
    """Load the test suite from JSON file."""
    path = get_test_suite_path()
    if not path.exists():
        print(f"Error: test_suite.json not found at {path}", file=sys.stderr)
        sys.exit(1)

    with open(path, "r") as f:
        return json.load(f)


def save_test_suite(tests: list) -> None:
    """Save the test suite to JSON file."""
    path = get_test_suite_path()
    with open(path, "w") as f:
        json.dump(tests, f, indent=2)
    print(f"Updated: {path}")


def print_test(test: dict, index: int = None) -> None:
    """Print a test in a readable format."""
    prefix = f"[{index}] " if index is not None else ""
    status = "PASS" if test.get("passes") else "FAIL"

    print(f"{prefix}Category: {test.get('category', 'unknown')}")
    print(f"   Description: {test.get('description', 'No description')}")
    print(f"   Status: {status}")
    print("   Steps:")
    for i, step in enumerate(test.get("steps", []), 1):
        print(f"      {i}. {step}")
    print()


def find_test_by_description(tests: list, description: str) -> tuple[int, dict] | None:
    """Find a test by its description (case-insensitive partial match)."""
    description_lower = description.lower()
    for i, test in enumerate(tests):
        if description_lower in test.get("description", "").lower():
            return i, test
    return None


def cmd_verify(tests: list) -> None:
    """Select 2 random passing tests for re-validation."""
    passing_tests = [(i, t) for i, t in enumerate(tests) if t.get("passes")]

    if not passing_tests:
        print("No passing tests available for verification.")
        return

    count = min(2, len(passing_tests))
    selected = random.sample(passing_tests, count)

    print(f"=== VERIFICATION TESTS ({count} selected) ===\n")
    for idx, test in selected:
        print_test(test, idx)


def cmd_feature(tests: list) -> None:
    """Get the next feature to implement (first non-passing test)."""
    for i, test in enumerate(tests):
        if not test.get("passes"):
            print("=== NEXT FEATURE TO IMPLEMENT ===\n")
            print_test(test, i)
            return

    print("All tests are passing! No pending features.")


def cmd_completed(tests: list, description: str) -> None:
    """Mark a test as passing by description."""
    result = find_test_by_description(tests, description)

    if result is None:
        print(f"Error: No test found matching '{description}'", file=sys.stderr)
        sys.exit(1)

    idx, test = result

    if test.get("passes"):
        print(f"Test already marked as passing: {test.get('description')}")
        return

    tests[idx]["passes"] = True
    save_test_suite(tests)
    print(f"Marked as COMPLETED: {test.get('description')}")


def cmd_fix_priority(tests: list, description: str) -> None:
    """Mark a test as failing (needs fix) by description."""
    result = find_test_by_description(tests, description)

    if result is None:
        print(f"Error: No test found matching '{description}'", file=sys.stderr)
        sys.exit(1)

    idx, test = result

    if not test.get("passes"):
        print(f"Test already marked as failing: {test.get('description')}")
        return

    tests[idx]["passes"] = False
    save_test_suite(tests)
    print(f"Marked as FIX PRIORITY: {test.get('description')}")


def main():
    parser = argparse.ArgumentParser(
        description="Manage test suite progress for autonomous iteration work.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
    up_next --verify                    # Get 2 random passing tests to re-validate
    up_next --feature                   # Get the next feature to implement
    up_next --completed "user login"    # Mark "user login" test as passing
    up_next --fix-priority "user login" # Mark "user login" test as needing fix
        """
    )

    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument(
        "--verify",
        action="store_true",
        help="Select 2 random passing tests for re-validation"
    )
    group.add_argument(
        "--feature",
        action="store_true",
        help="Get the next feature to implement (first non-passing)"
    )
    group.add_argument(
        "--completed",
        metavar="DESCRIPTION",
        help="Mark a test as passing by description"
    )
    group.add_argument(
        "--fix-priority",
        metavar="DESCRIPTION",
        help="Mark a test as failing (needs fix) by description"
    )

    args = parser.parse_args()

    tests = load_test_suite()

    if args.verify:
        cmd_verify(tests)
    elif args.feature:
        cmd_feature(tests)
    elif args.completed:
        cmd_completed(tests, args.completed)
    elif args.fix_priority:
        cmd_fix_priority(tests, args.fix_priority)


if __name__ == "__main__":
    main()
