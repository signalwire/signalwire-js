{
  "name": "@signalwire/call-fabric-migration-demo",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "description": "Migration demo from call-fabric-client-beta (v3 @signalwire/client) to v4 @signalwire/js SDK",
  "scripts": {
    "dev": "rm -rf node_modules/.vite && vite",
    "dev:sat": "rm -rf node_modules/.vite && SAT_TOKEN=$(node ../../scripts/issue-sat.js --env-file ../../.env) vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@signalwire/js": "4.0.0-rc.1",
    "@signalwire/web-components": "4.0.0-rc.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "vite": "^7.2.2"
  }
}
