# SignalWire Integration Test Configuration
# Copy this file to .env and fill in your actual values

# Your SignalWire space name (e.g., "your-space" from your-space.signalwire.com)
SW_SPACE=your-space-name

# Reference identifier for the subscriber (e.g., email address)
SW_SUBSCRIBER_REFERENCE=your-subscriber-reference

# Password for the subscriber reference
SW_SUBSCRIBER_REFERENCE_PASSWORD=your-subscriber-password

# SignalWire Project ID from your project settings
SW_PROJECT_ID=your-project-id

# SignalWire Project Token (not API token!)
SW_PROJECT_TOKEN=your-project-token

# Optional: Use an existing subscriber token instead of creating one
# If set, the test will skip step 1 (token creation) and use this token directly
SW_EXISTING_SUBSCRIBER_TOKEN=
