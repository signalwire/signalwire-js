{
  "name": "signalwire-browser-sdk",
  "version": "3.30.0-rc.0",
  "description": "SignalWire Browser SDK Monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "playground/*"
  ],
  "scripts": {
    "build": "npm run build:main && npm run build --workspaces",
    "build:main": "npm run build -w @signalwire/js",
    "build:web-components": "npm run build -w @signalwire/web-components",
    "build:kitchen-sink-demo": "npm run build -w @signalwire/kitchen-sink-js",
    "build:call-fabric-migration-demo": "npm run build -w @signalwire/call-fabric-migration-demo",
    "build:react-demo": "npm run build -w @signalwire/react-demo",
    "dev": "npm run dev --workspaces --if-present",
    "dev:main": "npm run dev -w @signalwire/js",
    "dev:web-components": "npm run dev -w @signalwire/web-components",
    "dev:kitchen-sink-demo": "npm run dev -w @signalwire/kitchen-sink-js",
    "dev:call-fabric-migration-demo": "npm run dev -w @signalwire/call-fabric-migration-demo",
    "dev:react-demo": "npm run dev -w @signalwire/react-demo",
    "test": "npm run test -w @signalwire/js",
    "test:ui": "npm run test:ui -w @signalwire/js",
    "test:integration": "npm run build:main && playwright test",
    "test:e2e": "npm run build:main && playwright test playwright_tests/e2e",
    "test:coverage": "npm run test:coverage -w @signalwire/js",
    "lint": "eslint packages/main/src",
    "lint:fix": "eslint --fix packages/main/src",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"playground/*/src/**/*.ts\"",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "rm -rf packages/*/dist packages/*/node_modules playground/*/dist playground/*/node_modules node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "build:docs": "node scripts/build-docs.mjs",
    "release": "changeset publish",
    "prepare": "husky",
    "sw-repo": "npx tsx scripts/dual-repo/index.ts",
    "test:dual-repo": "vitest --config scripts/dual-repo/vitest.config.ts --run",
    "test:dual-repo:coverage": "vitest --config scripts/dual-repo/vitest.config.ts --run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.29.7",
    "@custom-elements-manifest/analyzer": "^0.10.10",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "dotenv": "^16.4.5",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-sort-class-members": "^1.21.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "publint": "^0.3.15",
    "puppeteer": "^24.35.0",
    "size-limit": "^11.2.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "eslint": "$eslint",
    "minimatch": "^10.2.3"
  }
}
